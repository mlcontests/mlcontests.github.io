          "deadline": {
            "type": "string",
            "pattern": "\\d{1,2} [a-zA-Z]{3} \\d{4}",
            "description": "Final day for submissions. Format is 'D MMM YYYY'."
          },
          "registration-deadline": {
            "type": ["string", "null"],
            "pattern": "\\d{1,2} [a-zA-Z]{3} \\d{4}",
            "description": "Final day for registration. Format is 'D MMM YYYY'."
          },
          "launched": {
            "type": ["string", "null"],
            "pattern": "\\d{1,2} [a-zA-Z]{3} \\d{4}",
            "description": "First day of the competition. Format is 'D MMM YYYY'."
          },
          "added": {
            "type": "string",
            "pattern": "\\d{1,2} [a-zA-Z]{3} \\d{4}",
            "description": "Day on which the competition was added to the ML Contests site. Format is 'D MMM YYYY'."
          },
          "prize": {
            "type": ["string", "null"],
            "pattern": "^\\$\\d{1,3}(,\\d{3})*$",
            "description": "Total available prize pool. Unconditional cash or liquid cryptocurrencty prizes only, converted to USD. "
          },
          "platform": {
            "type": "string",
            "description": "Which platform is hosting the competition? E.g. 'Kaggle'/'DrivenData'/'Codabench'/'Independent'. "
          },
          "sponsor": {
            "type": ["string", "null"],
            "description": "List any organisations sponsoring the competition."
          },
          "conference": {
            "type": ["string", "null"],
            "description": "List any conference affiliation. E.g. 'NeurIPS', 'MICCAI'."
          },
          "conference-year": {
            "type": ["integer", "null"],
            "description": "If the competition is affiliated with a conference, enter the year of the conference here."
          },
          "additional_urls": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Any additional relevant links to competition information hosted elsewhere"
          }
        },
        "required": [
          "name",
          "url",
          "tags",
          "deadline",
          "prize",
          "platform",
          "sponsor"
        ]
      }
    }
  }
