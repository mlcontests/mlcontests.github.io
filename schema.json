{
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "A brief title describing the competition. Use task-oriented titles (e.g. 'Predict Stock Returns') as opposed to titles like 'Company X Stock Return Competition'.",
            "minLength": 10,
            "maxLength": 60
          },
          "url": {
            "type": "string",
            "description": "Link to the competition. Feel free to insert codes so you can track the source, or add '?ref=mlcontests'. "
          },
          "tags": {
            "type": "array",
